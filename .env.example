# ─── Core ───
API_PORT=3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_madness
NETWORK=monad

# ─── Auth ───
ADMIN_API_KEY=your-secret-key-here

# ─── External Services (set to 'mock' for local dev) ───
EDGE_PROXY_URL=https://valiron-edge-proxy.onrender.com
SANDBOX_API_URL=https://valiron.onrender.com
SANDBOX_RUNTIME=mock
REDIS_URL=mock

# ─── Sandbox Limits ───
MAX_CONCURRENT_SANDBOXES=32
SANDBOX_TIMEOUT_MS=60000

# ─── Frontend ───
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Monitoring (optional) ───
ALERT_SLACK_WEBHOOK=
ALERT_PAGERDUTY_KEY=
UPTIME_PING_URL=

# ─── IPFS (optional) ───
IPFS_API_URL=
IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# ─── x402 Payment Protocol (optional — omit to disable payment gating) ───
X402_PAY_TO=0xd907cccf352a49a01fcc287c8b94a1a2c4252f58
X402_NETWORK_ID=eip155:8453
# X402_FACILITATOR_URL=https://x402.org/facilitator

# ─── CDP API Keys (for Coinbase-hosted facilitator — optional) ───
# Get these at https://cdp.coinbase.com → Settings → API Keys
# CDP_API_KEY_ID=your-cdp-key-id
# CDP_API_KEY_SECRET=your-cdp-key-secret
